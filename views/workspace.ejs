<!-- ── SIDEBAR COLLAPSE + THEME TOGGLE LOGIC ─────────────────────────────── -->
<script>
  (function () {
    // ── Collapsible sidebar with fluid Column 2 resizing ──
    const sidebarContainer = document.getElementById('sidebarContainer');
    const sidebarToggle     = document.getElementById('sidebarToggle');
    const pdfMainCol        = document.getElementById('pdfMainCol');

    let sidebarCollapsed = false;

    sidebarToggle.addEventListener('click', () => {
      sidebarCollapsed = !sidebarCollapsed;

      sidebarContainer.classList.toggle('collapsed', sidebarCollapsed);
      sidebarToggle.classList.toggle('is-collapsed', sidebarCollapsed);

      // Column 2 fluidly expands to absorb the freed-up 20% when sidebar hides,
      // since Column 3 (AI panel) stays fixed at 30%.
      if (sidebarCollapsed) {
        sidebarContainer.style.width = '0%';
        pdfMainCol.style.width       = '70%';
      } else {
        sidebarContainer.style.width = '20%';
        pdfMainCol.style.width       = '50%';
      }

      // Re-render PDF pages after the transition completes so canvas
      // dimensions stay crisp at the new viewport width.
      setTimeout(() => {
        if (window.pdfViewer && typeof window.pdfViewer.refreshLayout === 'function') {
          window.pdfViewer.refreshLayout();
        }
      }, 320);
    });

    // ── Theme toggle (Sun/Moon) — may appear in either header variant ──
    document.querySelectorAll('#themeToggle').forEach(btn => {
      btn.addEventListener('click', () => {
        document.body.classList.toggle('light-mode');
      });
    });
  })();
</script>
</body>
</html>
