<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>StudyMind AI — Sign In</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Sora:wght@600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background:#0a0a0a; }
    .font-display { font-family: 'Sora', sans-serif; }
    .bg-grid {
      background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px);
      background-size: 28px 28px;
    }
  </style>
</head>
<body class="min-h-screen bg-grid flex items-center justify-center p-4">

  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <a href="/" class="inline-flex items-center gap-2 mb-3">
        <div class="w-8 h-8 rounded-lg bg-violet-600 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <span class="font-display text-2xl text-white font-bold">StudyMind AI</span>
      </a>
      <p class="text-zinc-500 text-sm">Your AI-powered study companion</p>
    </div>

    <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-8 shadow-2xl">
      <h1 class="font-display text-xl text-white font-semibold mb-6">Welcome back</h1>

      <% if (error && error.length > 0) { %>
        <div class="mb-4 p-3 bg-red-500/10 border border-red-500/30 rounded-lg text-red-400 text-sm">
          <%= error[0] %>
        </div>
      <% } %>
      <% if (success && success.length > 0) { %>
        <div class="mb-4 p-3 bg-emerald-500/10 border border-emerald-500/30 rounded-lg text-emerald-400 text-sm">
          <%= success[0] %>
        </div>
      <% } %>

      <form action="/auth/login" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm text-zinc-500 mb-1.5">Email address</label>
          <input type="email" name="email" required
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-2.5 text-white text-sm placeholder-zinc-600 focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition"
            placeholder="you@university.edu" />
        </div>
        <div>
          <label class="block text-sm text-zinc-500 mb-1.5">Password</label>
          <input type="password" name="password" required
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-4 py-2.5 text-white text-sm placeholder-zinc-600 focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition"
            placeholder="••••••••" />
        </div>
        <button type="submit"
          class="w-full bg-white hover:bg-zinc-100 text-zinc-900 font-semibold py-2.5 rounded-lg text-sm transition-colors mt-2">
          Sign in
        </button>
      </form>

      <p class="text-center text-zinc-600 text-sm mt-6">
        Don't have an account?
        <a href="/auth/signup" class="text-violet-400 hover:text-violet-300 transition">Create one</a>
      </p>
    </div>
  </div>

</body>
</html>
