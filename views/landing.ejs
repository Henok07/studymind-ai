<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>StudyMind AI — Learn smarter with AI</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Sora:wght@700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: #0a0a0a; color: #fff; -webkit-font-smoothing: antialiased; }
    .font-display { font-family: 'Sora', sans-serif; }

    /* Noise texture overlay */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      opacity: 0.4;
    }

    /* Radial glow */
    .hero-glow {
      position: absolute;
      top: -20%;
      left: 50%;
      transform: translateX(-50%);
      width: 900px;
      height: 600px;
      background: radial-gradient(ellipse at center, rgba(124,58,237,0.12) 0%, transparent 70%);
      pointer-events: none;
    }

    /* Grid background */
    .bg-grid {
      background-image:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
      background-size: 48px 48px;
    }

    /* Animated gradient border on CTA */
    .cta-primary {
      position: relative;
      background: #fff;
      color: #0a0a0a;
      font-weight: 600;
      border-radius: 9999px;
      transition: opacity 0.2s, transform 0.2s;
    }
    .cta-primary:hover { opacity: 0.88; transform: translateY(-1px); }

    .cta-secondary {
      background: transparent;
      color: #fff;
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 9999px;
      transition: border-color 0.2s, background 0.2s;
    }
    .cta-secondary:hover { border-color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.04); }

    /* Feature card */
    .feature-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 16px;
      transition: border-color 0.2s, background 0.2s;
    }
    .feature-card:hover {
      border-color: rgba(124,58,237,0.3);
      background: rgba(124,58,237,0.04);
    }

    /* Pill badge */
    .badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(124,58,237,0.12);
      border: 1px solid rgba(124,58,237,0.25);
      color: #a78bfa;
      font-size: 11px; font-weight: 600;
      padding: 4px 12px; border-radius: 9999px;
      letter-spacing: 0.04em; text-transform: uppercase;
    }

    /* Navbar blur */
    .navbar {
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      background: rgba(10,10,10,0.7);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    /* Scroll fade-in animation */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.7s ease forwards; }
    .delay-1 { animation-delay: 0.1s; opacity: 0; }
    .delay-2 { animation-delay: 0.22s; opacity: 0; }
    .delay-3 { animation-delay: 0.34s; opacity: 0; }
    .delay-4 { animation-delay: 0.46s; opacity: 0; }

    /* Demo preview mockup */
    .mockup-window {
      background: #111111;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      overflow: hidden;
    }
    .mockup-titlebar {
      background: #1a1a1a;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding: 10px 16px;
      display: flex; align-items: center; gap: 6px;
    }
    .dot { width: 10px; height: 10px; border-radius: 50%; }

    /* Highlight pill for hero text */
    .highlight { color: #a78bfa; }
  </style>
</head>
<body class="relative">

  <!-- ── NAVBAR ──────────────────────────────────────────────────────────── -->
  <nav class="navbar fixed top-0 inset-x-0 z-50">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-7 h-7 rounded-lg bg-violet-600 flex items-center justify-center flex-shrink-0 group-hover:bg-violet-500 transition-colors">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3
                 m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547
                 A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531
                 c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <span class="font-display text-[15px] text-white font-bold tracking-tight">StudyMind AI</span>
      </a>

      <!-- Nav links -->
      <div class="hidden md:flex items-center gap-6">
        <a href="#features" class="text-sm text-zinc-400 hover:text-white transition-colors">Features</a>
        <a href="#how" class="text-sm text-zinc-400 hover:text-white transition-colors">How it works</a>
      </div>

      <!-- Auth buttons -->
      <div class="flex items-center gap-2">
        <a href="/auth/login" class="cta-secondary text-sm px-4 py-1.5">Log in</a>
        <a href="/auth/signup" class="cta-primary text-sm px-5 py-1.5">Get Started</a>
      </div>
    </div>
  </nav>

  <!-- ── HERO ───────────────────────────────────────────────────────────── -->
  <section class="relative min-h-screen bg-grid flex flex-col items-center justify-center text-center px-6 pt-20 pb-16 overflow-hidden">
    <div class="hero-glow"></div>

    <div class="relative z-10 max-w-3xl mx-auto">
      <!-- Badge -->
      <div class="fade-up delay-1 mb-6">
        <span class="badge">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"/>
          </svg>
          AI-Powered Study Assistant
        </span>
      </div>

      <!-- Headline -->
      <h1 class="font-display fade-up delay-2 text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.05] tracking-tight text-white mb-5">
        An AI tutor<br class="hidden sm:block"/>
        <span class="highlight">made for you.</span>
      </h1>

      <!-- Sub-headline -->
      <p class="fade-up delay-3 text-base md:text-lg text-zinc-400 leading-relaxed max-w-xl mx-auto mb-8">
        Turns your learning materials into notes, interactive chats, quizzes, and more — instantly.
      </p>

      <!-- CTA buttons -->
      <div class="fade-up delay-4 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/auth/signup" class="cta-primary text-sm px-7 py-3 w-full sm:w-auto text-center">
          Start Learning — it's free
        </a>
        <a href="/auth/login" class="cta-secondary text-sm px-7 py-3 w-full sm:w-auto text-center text-zinc-300">
          Already have an account
        </a>
      </div>

      <!-- Social proof micro-text -->
      <p class="fade-up delay-4 text-xs text-zinc-600 mt-5">No credit card required &nbsp;·&nbsp; Works with any PDF</p>
    </div>

    <!-- Mockup preview -->
    <div class="relative z-10 mt-16 w-full max-w-4xl mx-auto fade-up delay-4">
      <div class="mockup-window shadow-2xl">
        <div class="mockup-titlebar">
          <div class="dot bg-red-500/70"></div>
          <div class="dot bg-yellow-500/70"></div>
          <div class="dot bg-green-500/70"></div>
          <span class="text-xs text-zinc-600 ml-3">StudyMind AI — Workspace</span>
        </div>
        <!-- Fake 3-column layout preview -->
        <div class="flex h-52 md:h-72">
          <!-- Sidebar column -->
          <div class="w-[18%] border-r border-white/5 bg-[#0e0e0e] p-3 flex flex-col gap-2">
            <div class="h-2 w-16 bg-white/10 rounded-full"></div>
            <div class="h-1.5 w-12 bg-white/5 rounded-full mt-2"></div>
            <div class="h-6 w-full bg-violet-600/20 border border-violet-600/30 rounded-md mt-1"></div>
            <div class="h-5 w-full bg-white/5 rounded-md"></div>
            <div class="h-5 w-full bg-white/5 rounded-md"></div>
            <div class="h-5 w-3/4 bg-white/5 rounded-md"></div>
          </div>
          <!-- PDF column -->
          <div class="flex-1 border-r border-white/5 bg-[#111] p-4 flex flex-col gap-2">
            <div class="h-2 w-full bg-white/10 rounded-full"></div>
            <div class="h-2 w-5/6 bg-white/7 rounded-full"></div>
            <div class="h-2 w-full bg-white/10 rounded-full mt-1"></div>
            <div class="h-2 w-4/5 bg-white/7 rounded-full"></div>
            <div class="h-2 w-full bg-white/10 rounded-full mt-1"></div>
            <div class="h-2 w-3/4 bg-white/7 rounded-full"></div>
            <!-- Floating menu simulation -->
            <div class="mt-3 self-center bg-[#1e1e1e] border border-white/10 rounded-lg px-3 py-2 flex gap-2">
              <div class="h-4 w-12 bg-violet-500/40 rounded-md"></div>
              <div class="h-4 w-14 bg-emerald-500/30 rounded-md"></div>
              <div class="h-4 w-16 bg-amber-500/30 rounded-md"></div>
            </div>
          </div>
          <!-- AI panel column -->
          <div class="w-[30%] bg-[#0e0e0e] p-3 flex flex-col gap-2">
            <div class="flex gap-1 mb-1">
              <div class="h-5 flex-1 bg-white/10 rounded-md"></div>
              <div class="h-5 flex-1 bg-violet-600/30 rounded-md"></div>
              <div class="h-5 flex-1 bg-white/10 rounded-md"></div>
            </div>
            <div class="h-2 w-full bg-white/8 rounded-full"></div>
            <div class="h-2 w-5/6 bg-white/5 rounded-full"></div>
            <div class="h-2 w-full bg-white/8 rounded-full"></div>
            <div class="h-2 w-3/4 bg-white/5 rounded-full mt-1"></div>
            <div class="h-2 w-full bg-white/8 rounded-full"></div>
            <div class="h-2 w-4/5 bg-violet-400/20 rounded-full mt-1"></div>
            <div class="h-2 w-full bg-violet-400/15 rounded-full"></div>
          </div>
        </div>
      </div>
      <!-- Glow under mockup -->
      <div class="absolute -bottom-8 inset-x-0 h-24 bg-gradient-to-t from-[#0a0a0a] to-transparent pointer-events-none"></div>
    </div>
  </section>

  <!-- ── FEATURES ───────────────────────────────────────────────────────── -->
  <section id="features" class="relative z-10 py-24 px-6 bg-[#0a0a0a]">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-xs uppercase tracking-widest text-violet-400 font-semibold mb-3">What you get</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white">Everything you need to study smarter</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- Feature 1 -->
        <div class="feature-card p-6">
          <div class="w-9 h-9 rounded-xl bg-violet-600/15 border border-violet-600/20 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">Interactive Chat</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">Highlight any passage and instantly get a clear, contextual explanation streamed in real time.</p>
        </div>

        <!-- Feature 2 -->
        <div class="feature-card p-6">
          <div class="w-9 h-9 rounded-xl bg-emerald-600/15 border border-emerald-600/20 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">Adaptive Quizzes</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">Generate multiple-choice quizzes from selected material. Get instant feedback and explanations per question.</p>
        </div>

        <!-- Feature 3 -->
        <div class="feature-card p-6">
          <div class="w-9 h-9 rounded-xl bg-amber-600/15 border border-amber-600/20 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">Smart Flashcards</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">Extract key concepts as flip-able flashcards. Save them to your personal deck and review any time.</p>
        </div>

        <!-- Feature 4 -->
        <div class="feature-card p-6">
          <div class="w-9 h-9 rounded-xl bg-sky-600/15 border border-sky-600/20 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h7"/>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">Section Summaries</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">Select large blocks of text and get a concise, structured summary with headings and key points.</p>
        </div>

        <!-- Feature 5 -->
        <div class="feature-card p-6">
          <div class="w-9 h-9 rounded-xl bg-rose-600/15 border border-rose-600/20 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">Mock Exams</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">Highlight an entire chapter and generate a 10-question mock exam to test your depth of understanding.</p>
        </div>

        <!-- Feature 6 -->
        <div class="feature-card p-6">
          <div class="w-9 h-9 rounded-xl bg-purple-600/15 border border-purple-600/20 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-white mb-2">PDF-First Workspace</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">Upload your lecture slides, textbooks, or notes. Your PDFs are stored privately and always accessible.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ───────────────────────────────────────────────────── -->
  <section id="how" class="relative z-10 py-24 px-6 bg-[#0a0a0a] border-t border-white/5">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs uppercase tracking-widest text-violet-400 font-semibold mb-3">Simple workflow</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-12">Up and running in 30 seconds</h2>

      <div class="flex flex-col md:flex-row items-start gap-8 text-left">
        <div class="flex-1">
          <div class="w-7 h-7 rounded-full bg-violet-600/20 border border-violet-600/30 text-violet-400 text-xs font-bold flex items-center justify-center mb-4">1</div>
          <h3 class="text-sm font-semibold text-white mb-2">Upload your PDF</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">Drag in any PDF — textbook chapters, lecture slides, research papers.</p>
        </div>
        <div class="hidden md:flex items-center pt-3 text-zinc-700">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
        <div class="flex-1">
          <div class="w-7 h-7 rounded-full bg-violet-600/20 border border-violet-600/30 text-violet-400 text-xs font-bold flex items-center justify-center mb-4">2</div>
          <h3 class="text-sm font-semibold text-white mb-2">Select any text</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">Highlight a sentence, paragraph, or entire section directly in the PDF reader.</p>
        </div>
        <div class="hidden md:flex items-center pt-3 text-zinc-700">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </div>
        <div class="flex-1">
          <div class="w-7 h-7 rounded-full bg-violet-600/20 border border-violet-600/30 text-violet-400 text-xs font-bold flex items-center justify-center mb-4">3</div>
          <h3 class="text-sm font-semibold text-white mb-2">Choose an action</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">A menu instantly appears — Explain, Quiz, Flashcards, Summarize, or Mock Exam.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FOOTER CTA ────────────────────────────────────────────────────── -->
  <section class="relative z-10 py-24 px-6 border-t border-white/5 text-center bg-[#0a0a0a]">
    <div class="max-w-xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">Ready to study smarter?</h2>
      <p class="text-sm text-zinc-500 mb-8">Join students already using StudyMind AI to ace their exams.</p>
      <a href="/auth/signup" class="cta-primary inline-block text-sm px-8 py-3">Get Started for Free</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="relative z-10 border-t border-white/5 py-6 px-6 bg-[#0a0a0a]">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 rounded bg-violet-600 flex items-center justify-center">
          <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <span class="text-xs text-zinc-600 font-medium">StudyMind AI</span>
      </div>
      <p class="text-xs text-zinc-700">© 2025 StudyMind AI. All rights reserved.</p>
    </div>
  </footer>

</body>
</html>
